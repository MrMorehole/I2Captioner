 "outputs": [{"localized_name": "image", "name": "image", "shape": 6, "type": "IMAGE", "links": [231]}, {"localized_name": "filename", "name": "filename", "shape": 6, "type": "STRING", "links": null}, {"localized_name": "total_images", "name": "total_images", "type": "INT", "links": null}], "properties": {"Node name for S&R": "I2Caption Loader", "ue_properties": {"widget_ue_connectable": {}, "input_ue_unconnectable": {}, "version": "7.8"}}, "widgets_values": ["/mnt/More/ComfyUI/output/batch/images", 0, "name", true]}, {"id": 95, "type": "PreviewImage", "pos": [-1700, -1530], "size": [360, 620], "flags": {}, "order": 24, "mode": 0, "inputs": [{"localized_name": "images", "name": "images", "type": "IMAGE", "link": 217}], "outputs": [], "properties": {"cnr_id": "comfy-core", "ver": "0.22.2", "Node name for S&R": "PreviewImage", "ue_properties": {"widget_ue_connectable": {}, "input_ue_unconnectable": {}, "version": "7.8"}}, "widgets_values": []}, {"id": 105, "type": "Note", "pos": [-580, -1030], "size": [620, 100], "flags": {"collapsed": false}, "order": 14, "mode": 0, "inputs": [], "outputs": [], "title": "Show Text Note", "properties": {"text": "Displays the generated Flux2 prompt so you can review it before generation runs.", "ue_properties": {"widget_ue_connectable": {}, "version": "7.8", "input_ue_unconnectable": {}}}, "widgets_values": ["Displays the generated prompt so you can review it before generation runs."], "color": "#5c1a4a", "bgcolor": "#1a1a1a"}, {"id": 96, "type": "PreviewImage", "pos": [500, -1820], "size": [390, 550], "flags": {}, "order": 29, "mode": 0, "inputs": [{"localized_name": "images", "name": "images", "type": "IMAGE", "link": 205}], "outputs": [], "properties": {"cnr_id": "comfy-core", "ver": "0.22.2", "Node name for S&R": "PreviewImage", "ue_properties": {"widget_ue_connectable": {}, "input_ue_unconnectable": {}, "version": "7.8"}}, "widgets_values": [], "color": "#5c1a1a", "bgcolor": "#350d0d"}, {"id": 103, "type": "Note", "pos": [-1280, -3000], "size": [670, 950], "flags": {"collapsed": false}, "order": 15, "mode": 0, "inputs": [], "outputs": [], "title": "Captioner Note", "properties": {"text": "Stage 1 \u2014 LLaVA describes the image visually. Stage 2 \u2014 Mistral rewrites that description as a Flux2 prompt. Both models run locally via Ollama.", "ue_properties": {"widget_ue_connectable": {}, "version": "7.8", "input_ue_unconnectable": {}}}, "widgets_values": ["Stage 1 \u2014 LLaVA describes the image visually. Stage 2 \u2014 Mistral rewrites that description as a Flux2 prompt. Both models run locally via Ollama.\n\nChoose a style preset to control the mood of the generated prompt: cinematic, anime, etc.\n\nOverride the style preset with your own custom prompt.\n\nAdd optional keywords in Style Hint to push the result further, e.g. golden hour, 8k.\n\nImages and captions save to the output_dir field on the node (default: /mnt/More/ComfyUI/output/batch)\nThe folder is created automatically if it doesn't exist\nFiles are saved as matched pairs using filename_prefix + counter:\n\nI2Caption_00001_.png - I2Caption_00001_.txt\n\nfilename prefix (default: I2Caption) can be changed per-run to organise batches.\nCounter is based on existing .png files in the folder so it always continues from where it left off.\nBoth files are written together inside the node no separate ComfyUI Save Image node needed."], "color": "#323", "bgcolor": "#535"}, {"id": 107, "type": "Note", "pos": [-580, -1210], "size": [620, 130], "flags": {"collapsed": false}, "order": 16, "mode": 0, "inputs": [], "outputs": [], "title": "Loras Note", "properties": {"text": "Optional LoRAs \u2014 set to 'None' to skip. Strength 0.5\u20130.9 is typical. Lower values blend more subtly with the base model.", "ue_properties": {"widget_ue_connectable": {}, "version": "7.8", "input_ue_unconnectable": {}}}, "widgets_values": ["Optional LoRAs \u2014 set to 'None' to skip. Strength 0.5\u20130.9 is typical. Lower values blend more subtly with the base model."], "color": "#3a1a5c", "bgcolor": "#1a1a1a"}, {"id": 6, "type": "CLIPTextEncode", "pos": [-220, -1950], "size": [360, 170], "flags": {}, "order": 23, "mode": 0, "inputs": [{"localized_name": "clip", "name": "clip", "type": "CLIP", "link": 172}, {"localized_name": "text", "name": "text", "type": "STRING", "widget": {"name": "text"}, "link": 240}], "outputs": [{"localized_name": "CONDITIONING", "name": "CONDITIONING", "type": "CONDITIONING", "slot_index": 0, "links": [41]}], "title": "CLIP Text Encode (Positive Prompt)", "properties": {"cnr_id": "comfy-core", "ver": "0.3.71", "Node name for S&R": "CLIPTextEncode", "ue_properties": {"widget_ue_connectable": {}, "version": "7.1", "input_ue_unconnectable": {}}}, "widgets_values": [""], "color": "#1a5c3a", "bgcolor": "#0d3520"}, {"id": 114, "type": "Fast Groups Bypasser (rgthree)", "pos": [-2090, -2060], "size": [350, 210], "flags": {}, "order": 17, "mode": 0, "inputs": [], "outputs": [{"name": "OPT_CONNECTION", "type": "*", "links": null}], "properties": {"matchColors": "", "matchTitle": "", "showNav": true, "showAllGraphs": true, "sort": "position", "customSortAlphabet": "", "toggleRestriction": "default", "ue_properties": {"widget_ue_connectable": {}, "input_ue_unconnectable": {}, "version": "7.8"}}, "color": "#322", "bgcolor": "#533"}, {"id": 86, "type": "ShowText|pysssss", "pos": [-1280, -1250], "size": [670, 800], "flags": {}, "order": 22, "mode": 0, "inputs": [{"localized_name": "text", "name": "text", "type": "STRING", "link": 218}], "outputs": [{"localized_name": "STRING", "name": "STRING", "shape": 6, "type": "STRING", "links": []}], "properties": {"cnr_id": "comfyui-custom-scripts", "ver": "609f3afaa74b2f88ef9ce8d939626065e3247469", "Node name for S&R": "ShowText|pysssss", "ue_properties": {"widget_ue_connectable": {}, "input_ue_unconnectable": {}, "version": "7.8"}}, "widgets_values": ["Anime-style portrait: Cheerful woman with updo, wearing vibrant blue low-cut outfit in cel-shaded line art. She poses confidently with one hand on hip, other on thigh, laughing or mid-conversation, open mouth, slightly closed eyes. Background is an outdoor setting with a soft, diffused blue sky and greenery, inspired by Studio Ghibli or modern anime aesthetics. Shallow depth of field emphasizes subject in natural lighting, smooth skin textures contrast with rougher fabric textures.", "\"Generate an anime-style image featuring two characters dressed in traditional Indian attire, standing on a rocky outcropping overlooking a waterfall in a lush forest. The figure on the left is adorned in a blue sari and holds a red flower, while the one on the right wears purple and holds a yellow flower. Both figures hold an object, possibly a lamp or religious item, with raised hands towards each other.\n\nThe background includes a cascading waterfall surrounded by dense greenery, creating a serene Studio Ghibli-inspired setting. The lighting is soft and diffused, suggesting early morning or late afternoon light conditions. Rich and saturated colors fill the scene, with contrasting greens of foliage against blue and purple hues of saris.\n\nThe image exudes tranquility and harmony, as suggested by the peaceful setting and expressive character features. The texture of the foliage and smoothness of the waterfall add depth to the composition, while background elements provide context for the location. The overall focus is on the visual content, with no visible text.\""], "color": "#323", "bgcolor": "#535"}, {"id": 118, "type": "I2Caption", "pos": [-1280, -1950], "size": [670, 660], "flags": {}, "order": 20, "mode": 0, "inputs": [{"localized_name": "image", "name": "image", "type": "IMAGE", "link": 228}, {"localized_name": "ollama_url", "name": "ollama_url", "type": "STRING", "widget": {"name": "ollama_url"}, "link": null}, {"localized_name": "vision_model", "name": "vision_model", "type": "STRING", "widget": {"name": "vision_model"}, "link": null}, {"localized_name": "mistral_model", "name": "mistr